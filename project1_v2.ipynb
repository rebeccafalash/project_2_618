    "#Q3\n",
    "\n",
    "comp_q3 = q3_df.copy()\n",
    "\n",
    "# Depression and PA by age group\n",
    "print(\"Mean Depression Score and Physical Activity by Age Group:\")\n",
    "depression_by_age = comp_q3.groupby(\"Age_Group\", observed=True)[[\"Depression_Score\", \"Physical_Activity\"]].agg([\"mean\", \"std\"]).round(3)\n",
    "display(depression_by_age)\n",
    "\n",
    "# Compare by Gender and Age Group\n",
    "print(\"\\n\\nMean Depression Score by Gender and Age Group:\")\n",
    "depression_gender_age = comp_q3.groupby([\"Gender\", \"Age_Group\"], observed=True)[\"Depression_Score\"].agg([\"mean\", \"std\"]).round(3)\n",
    "display(depression_gender_age)\n",
    "\n",
    "print(\"\\n\\nMean Physical Activity by Gender and Age Group:\")\n",
    "activity_gender_age = comp_q3.groupby([\"Gender\", \"Age_Group\"], observed=True)[\"Physical_Activity\"].agg([\"mean\", \"std\"]).round(3)\n",
    "display(activity_gender_age)\n",
    "\n",
    "# Line plot and Heatmap\n",
    "fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n",
    "\n",
    "depression_pivot = comp_q3.groupby([\"Age_Group\", \"Gender\"], observed=True)[\"Depression_Score\"].mean().unstack()\n",
    "depression_pivot.plot(ax=axes[0], marker='o', linewidth=2)\n",
    "axes[0].set_title(\"Depression Score Trends by Age Group\")\n",
    "axes[0].set_xlabel(\"Age Group\")\n",
    "axes[0].set_ylabel(\"Average Depression Score\")\n",
    "axes[0].legend(title=\"Gender\")\n",
    "axes[0].grid(True, alpha=0.3)\n",
    "\n",
    "activity_pivot = comp_q3.groupby([\"Gender\", \"Age_Group\"], observed=True)[\"Physical_Activity\"].mean().unstack()\n",
    "sns.heatmap(activity_pivot, annot=True, fmt=\".2f\", cmap=\"YlOrRd\", ax=axes[1], cbar_kws={\"label\": \"Avg Physical Activity\"})\n",
    "axes[1].set_title(\"Physical Activity by Gender and Age Group\")\n",
    "axes[1].set_xlabel(\"Age Group\")\n",
    "axes[1].set_ylabel(\"Gender\")\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()\n"
   ]

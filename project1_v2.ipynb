    "if p_value < 0.05:\n",
    "    print(\"Conclusion: Reject the null hypothesis. CGPA differs by sleep category.\")\n",
    "else:\n",
    "    print(\"Conclusion: Fail to reject the null hypothesis. There is no significant difference in CGPA.\")\n",
    "\n"

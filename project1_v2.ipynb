    "#Q3 \n",
    "\n",
    "# Strip whitespace\n",
    "df_habits.columns = df_habits.columns.str.strip()\n",
    "df_MH.columns = df_MH.columns.str.strip()\n",
    "\n",
    "# Rename columns\n",
    "df_habits = df_habits.rename(columns={  \"gender\": \"Gender\", \"age\": \"Age\"})\n",
    "\n",
    "# Convert from categorical to numeric\n",
    "activity_mapping = {'Low': 1, 'Moderate': 2, 'High': 3}\n",
    "df_MH['Physical_Activity_numeric'] = df_MH['Physical_Activity'].map(activity_mapping)\n",
    "\n",
    "# Group each dataset\n",
    "HB_Q3 = (df_habits.groupby([\"Gender\", \"Age\"]).agg({  \"exercise_frequency\": \"mean\"}).reset_index())\n",
    "\n",
    "MH_Q3 = (df_MH.groupby([\"Gender\", \"Age\"]).agg({\n",
    "        \"Depression_Score\": \"mean\",\n",
    "        \"Physical_Activity_numeric\": \"mean\",\n",
    "        \"Anxiety_Score\": \"mean\",\n",
    "        \"Stress_Level\": \"mean\"\n",
    "    }).reset_index().rename(columns={\"Physical_Activity_numeric\": \"Physical_Activity\"})\n",
    ")\n",
    "\n",
    "# Merge the datasets on Gender and Age\n",
    "df_q3 = pd.merge(HB_Q3, MH_Q3, on=[\"Gender\", \"Age\"], how=\"inner\")\n",
    "\n",
    "print(\"✓ Merged Q3 dataset for Physical Activity & Depression Analysis:\")\n",
    "print(f\"Shape: {df_q3.shape}\")\n",
    "print(f\"Columns: {df_q3.columns.tolist()}\")\n",
    "print(f\"\\nData preview:\")\n",
    "display(df_q3)"
   ]

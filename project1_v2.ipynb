    "#Q3 \n",
    "\n",
    "q3_df = df_q3.copy()\n",
    "\n",
    "cols = [\n",
    "    \"exercise_frequency\",\n",
    "    \"Physical_Activity\",\n",
    "    \"Depression_Score\",\n",
    "    \"Anxiety_Score\",\n",
    "    \"Stress_Level\"\n",
    "]\n",
    "\n",
    "# Calculations\n",
    "q3_stats = pd.DataFrame({\n",
    "    \"Mean\": q3_df[cols].mean(),\n",
    "    \"Median\": q3_df[cols].median(),\n",
    "    \"Min\": q3_df[cols].min(),\n",
    "    \"Max\": q3_df[cols].max(),\n",
    "    \"Range\": q3_df[cols].max() - q3_df[cols].min(),\n",
    "    \"Variance\": q3_df[cols].var(),\n",
    "    \"Std Dev\": q3_df[cols].std()\n",
    "}).round(3)\n",
    "\n",
    "print(\"Overall Descriptive Statistics for Q3:\")\n",
    "display(q3_stats)\n",
    "\n",
    "#  age groups \n",
    "q3_df[\"Age_Group\"] = pd.cut(\n",
    "    q3_df[\"Age\"],\n",
    "    bins=[17, 20, 23, 26],\n",
    "    labels=[\"18-20\", \"21-23\", \"24-26\"]\n",
    ")\n",
    "\n",
    "# Compare depression and physical activity by age group\n",
    "print(\"\\n\\nDepression and Physical Activity by Age Group:\")\n",
    "age_comparison = q3_df.groupby(\"Age_Group\", observed=True)[[\"Depression_Score\", \"Physical_Activity\", \"exercise_frequency\"]].agg([\"mean\", \"median\", \"std\"]).round(3)\n",
    "\n",
    "display(age_comparison)\n",
    "\n",
    "# Compare by gender and age group\n",
    "print(\"\\n\\nMean Depression Score by Gender and Age Group:\")\n",
    "depression_by_gender_age = q3_df.groupby([\"Gender\", \"Age_Group\"], observed=True)[\"Depression_Score\"].agg([\"mean\", \"median\", \"std\"]).round(3)\n",
    "\n",
    "display(depression_by_gender_age)\n",
    "\n",
    "print(\"\\n\\nMean Physical Activity by Gender and Age Group:\")\n",
    "activity_by_gender_age = q3_df.groupby([\"Gender\", \"Age_Group\"], observed=True)[\"Physical_Activity\"].agg([\"mean\", \"median\", \"std\"]).round(3)\n",
    "\n",
    "display(activity_by_gender_age)"
   ]
